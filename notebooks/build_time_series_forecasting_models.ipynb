    "    axes[idx].plot(pred_df.index, pred_df['Actual'], label='Actual', color='black', linewidth=2)\n",
    "    axes[idx].plot(pred_df.index, pred_df['Predicted'], label='Predicted', color=color, linewidth=2, linestyle='--')\n",
    "    axes[idx].axvline(x=train_data.index[-1], color='gray', linestyle='--', alpha=0.5)\n",
    "    axes[idx].set_title(f'{name}\\nRMSE: ${results[idx][\"RMSE\"]:.2f}', fontsize=12)\n",
    "    axes[idx].set_xlabel('Date')\n",
