   "source": [
    "# Cell 6a: ARIMA Parameter Selection (FIXED)\n",
    "\n",
    "import warnings\n",
    "warnings.filterwarnings('ignore')\n",
    "\n",
    "# ============================================================\n",
    "# STEP 1: Check pmdarima availability\n",
    "# ============================================================\n",
    "try:\n",
    "    from pmdarima import auto_arima\n",
    "    PMDARIMA_AVAILABLE = True\n",
    "    print(\"✅ pmdarima is installed and available!\")\n",
    "except ImportError:\n",
    "    PMDARIMA_AVAILABLE = False\n",
    "    print(\"⚠️ pmdarima is NOT installed\")\n",
    "    print(\"   To install: pip install pmdarima\")\n",
    "    print(\"   Using manual parameter selection instead...\")\n",
    "\n",
    "# ============================================================\n",
    "# STEP 2: Verify train_data exists\n",
    "# ============================================================\n",
    "try:\n",
    "    print(f\"\\n📊 Train data length: {len(train_data)}\")\n",
    "    print(f\"   Train data range: {train_data.index.min()} to {train_data.index.max()}\")\n",
    "except NameError:\n",
    "    print(\"❌ ERROR: train_data is not defined!\")\n",
    "    print(\"   Please run the data preparation cells first.\")\n",
    "    raise\n",
    "\n",
    "# ============================================================\n",
    "# STEP 3: ARIMA Parameter Selection\n",
    "# ============================================================\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"🔍 ARIMA Parameter Selection\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Initialize variables\n",
    "best_p, best_d, best_q = 1, 1, 1  # Default fallback\n",
    "best_score = float('inf')\n",
    "best_model = None\n",
    "\n",
    "if PMDARIMA_AVAILABLE:\n",
    "    print(\"\\n📌 Using auto_arima for automated parameter selection...\")\n",
    "    print(\"   (This may take 1-2 minutes)\")\n",
    "    \n",
    "    try:\n",
    "        # Use auto_arima\n",
    "        auto_model = auto_arima(\n",
    "            train_data,\n",
    "            start_p=0,\n",
    "            max_p=5,\n",
    "            start_d=1,\n",
    "            max_d=2,\n",
    "            start_q=0,\n",
    "            max_q=5,\n",
    "            seasonal=False,\n",
    "            stepwise=True,\n",
    "            trace=True,\n",
    "            error_action='ignore',\n",
    "            suppress_warnings=True,\n",
    "            n_fits=20,\n",
    "            information_criterion='aic'\n",
    "        )\n",
    "        \n",
    "        # Extract best parameters\n",
    "        best_p = auto_model.order[0]\n",
    "        best_d = auto_model.order[1]\n",
    "        best_q = auto_model.order[2]\n",
    "        best_score = auto_model.aic()  # Capture the AIC score\n",
    "        best_model = auto_model\n",
    "        \n",
    "        print(f\"\\n✅ Best ARIMA parameters found by auto_arima:\")\n",
    "        print(f\"   ARIMA({best_p}, {best_d}, {best_q})\")\n",
    "        print(f\"   AIC: {best_score:.2f}\")\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(f\"\\n⚠️ auto_arima failed with error: {e}\")\n",
    "        print(\"   Falling back to manual parameter selection...\")\n",
    "        PMDARIMA_AVAILABLE = False\n",
    "\n",
    "# Manual parameter selection (if auto_arima not available or failed)\n",
    "if not PMDARIMA_AVAILABLE:\n",
    "    print(\"\\n📌 Using manual grid search for parameter selection...\")\n",
