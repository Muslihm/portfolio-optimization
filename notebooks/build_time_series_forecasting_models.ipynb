    "    q_values = range(0, 4)\n",
    "    \n",
    "    best_score = float('inf')\n",
    "    best_params = None\n",
    "    best_model = None\n",
    "    \n",
    "    total_combinations = len(p_values) * len(d_values) * len(q_values)\n",
    "    tested = 0\n",
    "    \n",
    "    for p in p_values:\n",
    "        for d in d_values:\n",
    "            for q in q_values:\n",
    "                try:\n",
    "                    # Fit ARIMA model\n",
    "                    model = ARIMA(train_data, order=(p, d, q))\n",
    "                    model_fit = model.fit()\n",
    "                    aic = model_fit.aic\n",
    "                    \n",
    "                    # Update best model if AIC is lower\n",
    "                    if aic < best_score:\n",
    "                        best_score = aic\n",
    "                        best_params = (p, d, q)\n",
    "                        best_model = model_fit\n",
    "                    \n",
    "                    tested += 1\n",
    "                    print(f\"   ARIMA({p},{d},{q}) - AIC: {aic:.2f}\")\n",
    "                    \n",
    "                except Exception as e:\n",
    "                    print(f\"   ARIMA({p},{d},{q}) - Failed: {str(e)[:50]}\")\n",
    "                    continue\n",
    "    \n",
    "    # Display results\n",
    "    if best_params is not None:\n",
    "        best_p, best_d, best_q = best_params\n",
    "        print(f\"\\n✅ Best ARIMA parameters found by grid search:\")\n",
    "        print(f\"   ARIMA({best_p}, {best_d}, {best_q})\")\n",
    "        print(f\"   AIC: {best_score:.2f}\")\n",
    "    else:\n",
    "        print(\"\\n❌ No valid ARIMA model found!\")\n",
    "        print(\"   Using fallback parameters: ARIMA(1,1,1)\")\n",
    "        best_p, best_d, best_q = 1, 1, 1\n",
