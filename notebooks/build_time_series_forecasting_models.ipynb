   "source": [
    "# Cell 8b: Complete ML Models (Includes Data Preparation)\n",
    "\n",
    "print(\"🚀 Building ML Models (Alternative to LSTM)\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "from sklearn.ensemble import RandomForestRegressor\n",
    "from sklearn.neural_network import MLPRegressor\n",
    "from sklearn.linear_model import Ridge\n",
    "from sklearn.preprocessing import MinMaxScaler\n",
    "from sklearn.metrics import mean_absolute_error, mean_squared_error\n",
    "\n",
    "# ============================================================\n",
    "# STEP 1: Check if data exists, if not prepare it\n",
    "# ============================================================\n",
    "\n",
    "# Check if train_data and test_data exist\n",
    "try:\n",
    "    print(f\"✅ train_data: {len(train_data)} rows\")\n",
    "    print(f\"✅ test_data: {len(test_data)} rows\")\n",
    "except NameError:\n",
    "    print(\"❌ train_data/test_data not found! Loading data...\")\n",
    "    # Load data if needed\n",
    "    import yfinance as yf\n",
    "    tsla = yf.Ticker('TSLA')\n",
    "    tsla_data = tsla.history(start='2015-01-01', end='2026-06-30')\n",
    "    tsla_close = tsla_data['Close']\n",
    "    \n",
    "    # Split data\n",
    "    train_data = tsla_close[tsla_close.index <= '2024-12-31']\n",
    "    test_data = tsla_close[tsla_close.index >= '2025-01-01']\n",
    "    print(f\"✅ Data loaded: {len(train_data)} train, {len(test_data)} test\")\n",
    "\n",
    "# ============================================================\n",
    "# STEP 2: Prepare Data (Create scaler and sequences)\n",
    "# ============================================================\n",
    "\n",
    "print(\"\\n📊 Preparing data for ML models...\")\n",
    "\n",
    "# Create scaler\n",
    "scaler = MinMaxScaler()\n",
    "\n",
    "# Scale the data\n",
    "train_scaled = scaler.fit_transform(train_data.values.reshape(-1, 1))\n",
    "test_scaled = scaler.transform(test_data.values.reshape(-1, 1))\n",
    "\n",
    "print(f\"   ✅ Data scaled successfully\")\n",
    "print(f\"   Training data range: {train_scaled.min():.3f} to {train_scaled.max():.3f}\")\n",
    "print(f\"   Test data range: {test_scaled.min():.3f} to {test_scaled.max():.3f}\")\n",
    "\n",
    "# Define window size\n",
    "window_size = 60\n",
    "\n",
    "# Create sequences function\n",
    "def create_sequences(data, window_size):\n",
    "    X, y = [], []\n",
    "    for i in range(window_size, len(data)):\n",
    "        X.append(data[i-window_size:i])\n",
    "        y.append(data[i])\n",
    "    return np.array(X), np.array(y)\n",
    "\n",
    "# Create sequences\n",
    "X_train, y_train = create_sequences(train_scaled.flatten(), window_size)\n",
    "X_test, y_test = create_sequences(test_scaled.flatten(), window_size)\n",
    "\n",
    "print(f\"\\n   ✅ Sequences created:\")\n",
    "print(f\"   X_train shape: {X_train.shape}\")\n",
    "print(f\"   y_train shape: {y_train.shape}\")\n",
    "print(f\"   X_test shape: {X_test.shape}\")\n",
    "print(f\"   y_test shape: {y_test.shape}\")\n",
    "\n",
    "# ============================================================\n",
    "# STEP 3: Train ML Models\n",
    "# ============================================================\n",
    "\n",
    "print(\"\\n\" + \"=\"*60)\n",
    "print(\"🚀 Training ML Models...\")\n",
    "print(\"=\"*60)\n",
    "\n",
    "# Model 1: Random Forest\n",
    "print(\"\\n📌 Training Random Forest...\")\n",
    "rf_model = RandomForestRegressor(\n",
    "    n_estimators=100,\n",
    "    max_depth=20,\n",
    "    min_samples_split=5,\n",
    "    min_samples_leaf=2,\n",
    "    random_state=42,\n",
    "    n_jobs=-1\n",
    ")\n",
    "rf_model.fit(X_train, y_train)\n",
    "rf_pred_scaled = rf_model.predict(X_test)\n",
    "print(\"   ✅ Random Forest complete\")\n",
    "\n",
    "# Model 2: MLP Neural Network\n",
    "print(\"📌 Training MLP Neural Network...\")\n",
    "mlp_model = MLPRegressor(\n",
    "    hidden_layer_sizes=(100, 50, 25),\n",
    "    activation='relu',\n",
    "    solver='adam',\n",
    "    max_iter=500,\n",
    "    random_state=42,\n",
    "    early_stopping=True,\n",
    "    validation_fraction=0.1,\n",
    "    n_iter_no_change=10,\n",
    "    verbose=False\n",
    ")\n",
    "mlp_model.fit(X_train, y_train)\n",
    "mlp_pred_scaled = mlp_model.predict(X_test)\n",
    "print(\"   ✅ MLP Neural Network complete\")\n",
    "\n",
    "# Model 3: Ridge Regression (baseline)\n",
    "print(\"📌 Training Ridge Regression...\")\n",
    "ridge_model = Ridge(alpha=1.0)\n",
    "ridge_model.fit(X_train, y_train)\n",
    "ridge_pred_scaled = ridge_model.predict(X_test)\n",
    "print(\"   ✅ Ridge Regression complete\")\n",
    "\n",
    "# ============================================================\n",
    "# STEP 4: Inverse Transform Predictions\n",
    "# ============================================================\n",
    "\n",
    "print(\"\\n📊 Inverse transforming predictions...\")\n",
    "\n",
    "rf_pred = scaler.inverse_transform(rf_pred_scaled.reshape(-1, 1))\n",
    "mlp_pred = scaler.inverse_transform(mlp_pred_scaled.reshape(-1, 1))\n",
    "ridge_pred = scaler.inverse_transform(ridge_pred_scaled.reshape(-1, 1))\n",
    "actual_test = test_data.values[window_size:]\n",
    "\n",
    "# Create DataFrames\n",
    "rf_predictions = pd.DataFrame({\n",
    "    'Actual': actual_test,\n",
    "    'Predicted': rf_pred.flatten()\n",
    "}, index=test_data.index[window_size:])\n",
    "\n",
    "mlp_predictions = pd.DataFrame({\n",
    "    'Actual': actual_test,\n",
    "    'Predicted': mlp_pred.flatten()\n",
    "}, index=test_data.index[window_size:])\n",
    "\n",
    "ridge_predictions = pd.DataFrame({\n",
    "    'Actual': actual_test,\n",
