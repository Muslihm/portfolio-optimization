    "# Cell 4: Stationarity Test\n",
    "\n",
    "def adf_test_stationarity(series, title):\n",
    "    \"\"\"\n",
    "    Perform ADF test and check stationarity\n",
    "    \"\"\"\n",
    "    result = adfuller(series.dropna())\n",
    "    print(f\"\\n📊 ADF Test Results - {title}\")\n",
    "    print(\"=\"*60)\n",
    "    print(f\"ADF Statistic: {result[0]:.6f}\")\n",
    "    print(f\"p-value: {result[1]:.6f}\")\n",
    "    print(f\"Critical Values:\")\n",
    "    for key, value in result[4].items():\n",
    "        print(f\"   {key}: {value:.6f}\")\n",
    "    \n",
    "    if result[1] <= 0.05:\n",
    "        print(f\"\\n✅ {title} is STATIONARY (p-value < 0.05)\")\n",
    "        return True\n",
    "    else:\n",
    "        print(f\"\\n❌ {title} is NON-STATIONARY (p-value >= 0.05)\")\n",
    "        print(f\"   Differencing required\")\n",
    "        return False\n",
    "\n",
    "# Test original prices\n",
    "adf_test_stationarity(train_data, \"Original Prices\")\n",
    "\n",
    "# Test returns (first difference)\n",
    "train_returns = train_data.diff().dropna()\n",
    "adf_test_stationarity(train_returns, \"First Differences (Returns)\")\n",
    "\n",
    "# Determine d for ARIMA\n",
    "d = 1  # First difference is needed\n",
    "print(f\"\\n✅ Recommended differencing order (d): {d}\")"
   ]
  },
