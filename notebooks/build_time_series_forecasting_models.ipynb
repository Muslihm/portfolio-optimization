    "# Cell 8a: Data Preparation for LSTM\n",
    "\n",
    "def create_sequences(data, window_size):\n",
    "    \"\"\"\n",
    "    Create sequences for LSTM training.\n",
    "    \"\"\"\n",
    "    X, y = [], []\n",
    "    for i in range(window_size, len(data)):\n",
    "        X.append(data[i-window_size:i, 0])\n",
    "        y.append(data[i, 0])\n",
    "    return np.array(X), np.array(y)\n",
    "\n",
    "# Normalize data for LSTM\n",
    "scaler = MinMaxScaler()\n",
    "train_scaled = scaler.fit_transform(train_data.values.reshape(-1, 1))\n",
    "test_scaled = scaler.transform(test_data.values.reshape(-1, 1))\n",
    "\n",
    "# Define window size (use 60 days to predict next day)\n",
    "window_size = 60\n",
    "\n",
    "# Create sequences\n",
    "X_train, y_train = create_sequences(train_scaled, window_size)\n",
    "X_test, y_test = create_sequences(test_scaled, window_size)\n",
    "\n",
    "# Reshape for LSTM input (samples, timesteps, features)\n",
    "X_train_lstm = X_train.reshape(X_train.shape[0], X_train.shape[1], 1)\n",
    "X_test_lstm = X_test.reshape(X_test.shape[0], X_test.shape[1], 1)\n",
    "\n",
    "print(\"📊 LSTM Data Preparation:\")\n",
    "print(\"=\"*60)\n",
    "print(f\"Training sequences: {X_train_lstm.shape[0]}\")\n",
    "print(f\"Training shape: {X_train_lstm.shape}\")\n",
    "print(f\"Test sequences: {X_test_lstm.shape[0]}\")\n",
    "print(f\"Test shape: {X_test_lstm.shape}\")\n",
    "print(f\"Window size: {window_size} days\")\n",
    "print(f\"Features: 1 (Closing Price)\")"
   ]
